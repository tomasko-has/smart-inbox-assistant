# Copy this file to .env and fill in your own values
ANTHROPIC_API_KEY=your-api-key-here
PORT=3000

# --- Optional: webhook protection (recommended in production) ---
# If set, POST /api/messages requires the "x-webhook-token" header
# with this exact value. Leave unset for open local development.
# WEBHOOK_TOKEN=some-long-random-string

# --- Optional: daily cap on processed messages (default: 100) ---
# Protects against runaway AI costs.
# DAILY_MESSAGE_LIMIT=100

# --- Optional: real email trigger via IMAP ---
# If these are set, the server will watch the mailbox and process
# every new incoming email automatically.
# For Gmail: enable 2-Step Verification, then create an App Password
# (Google Account -> Security -> 2-Step Verification -> App passwords)
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=your.test.account@gmail.com
# IMAP_PASSWORD=your-16-char-app-password